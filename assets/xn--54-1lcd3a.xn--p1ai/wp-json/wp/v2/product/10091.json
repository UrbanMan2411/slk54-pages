{"id":10091,"date":"2024-05-16T15:09:23","date_gmt":"2024-05-16T08:09:23","guid":{"rendered":"https:\/\/xn--54-1lcd3a.xn--p1ai\/product\/%d0%ba%d0%be%d1%80%d0%b0%d0%b1%d0%b5%d0%bb%d1%8c%d0%bd%d0%b0%d1%8f-%d0%b4%d0%be%d1%81%d0%ba%d0%b0-xl-classic\/"},"modified":"2024-05-20T11:34:35","modified_gmt":"2024-05-20T04:34:35","slug":"%d0%ba%d0%be%d1%80%d0%b0%d0%b1%d0%b5%d0%bb%d1%8c%d0%bd%d0%b0%d1%8f-%d0%b4%d0%be%d1%81%d0%ba%d0%b0-xl-classic","status":"publish","type":"product","link":"https:\/\/xn--54-1lcd3a.xn--p1ai\/product\/%d0%ba%d0%be%d1%80%d0%b0%d0%b1%d0%b5%d0%bb%d1%8c%d0%bd%d0%b0%d1%8f-%d0%b4%d0%be%d1%81%d0%ba%d0%b0-xl-classic\/","title":{"rendered":"\u041a\u043e\u0440\u0430\u0431\u0435\u043b\u044c\u043d\u0430\u044f \u0434\u043e\u0441\u043a\u0430 XL Classic"},"content":{"rendered":"<p>\u041a\u043e\u0440\u0430\u0431\u0435\u043b\u044c\u043d\u0430\u044f \u0434\u043e\u0441\u043a\u0430 XL &#8211; \u043f\u0440\u043e\u0444\u0438\u043b\u044c \u0438\u043c\u0438\u0442\u0438\u0440\u0443\u044e\u0449\u0438\u0439 \u0434\u0435\u0440\u0435\u0432\u044f\u043d\u043d\u0443\u044e \u0434\u043e\u0441\u043a\u0443, \u0441 \u0443\u0432\u0435\u043b\u0438\u0447\u0435\u043d\u043d\u043e\u0439 \u0448\u0438\u0440\u0438\u043d\u043e\u0439 \u043f\u0430\u043d\u0435\u043b\u0438. \u041d\u0430\u0438\u0431\u043e\u043b\u0435\u0435 \u0440\u0430\u0441\u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0435\u043d\u043d\u0430\u044f \u0444\u043e\u0440\u043c\u0430 \u0432\u0438\u043d\u0438\u043b\u043e\u0432\u043e\u0433\u043e \u0441\u0430\u0439\u0434\u0438\u043d\u0433\u0430 \u0432 \u0420\u043e\u0441\u0441\u0438\u0438. \u0421\u043e\u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u0435 \u0434\u043b\u0438\u043d\u044b \u0438 \u0448\u0438\u0440\u0438\u043d\u044b \u043f\u0430\u043d\u0435\u043b\u0438 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0438\u0432\u0430\u0435\u0442 \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e \u043f\u043e\u043b\u0435\u0437\u043d\u0443\u044e \u043f\u043b\u043e\u0449\u0430\u0434\u044c \u0438 \u0438\u043c\u0438\u0442\u0430\u0446\u0438\u044e \u0434\u0435\u0440\u0435\u0432\u044f\u043d\u043d\u043e\u0433\u043e \u0444\u0430\u0441\u0430\u0434\u0430. \u0420\u0435\u0430\u043b\u0438\u0441\u0442\u0438\u0447\u043d\u0430\u044f \u0442\u0435\u043a\u0441\u0442\u0443\u0440\u0430 \u0441\u0430\u0439\u0434\u0438\u043d\u0433\u0430 \u0434\u043e\u0441\u0442\u043e\u0432\u0435\u0440\u043d\u043e \u043f\u043e\u0432\u0442\u043e\u0440\u044f\u0435\u0442 \u0432\u043e\u043b\u043d\u043e\u043e\u0431\u0440\u0430\u0437\u043d\u044b\u0439 \u0440\u0438\u0441\u0443\u043d\u043e\u043a \u0433\u043e\u0434\u043e\u0432\u044b\u0445 \u043a\u043e\u043b\u0435\u0446 \u043d\u0430\u0442\u0443\u0440\u0430\u043b\u044c\u043d\u043e\u0439 \u0434\u0440\u0435\u0432\u0435\u0441\u0438\u043d\u044b, \u0430 \u0442\u0430\u043a\u0436\u0435 \u043f\u0440\u0438\u0440\u043e\u0434\u043d\u044b\u0439 \u0443\u0437\u043e\u0440 \u0441\u0435\u0440\u0434\u0446\u0435\u0432\u0438\u043d\u043d\u044b\u0445 \u043b\u0443\u0447\u0435\u0439 \u0434\u0435\u0440\u0435\u0432\u0430. \u041e\u0440\u043d\u0430\u043c\u0435\u043d\u0442 \u043f\u0430\u043d\u0435\u043b\u0435\u0439, \u0432\u043e\u0441\u0441\u043e\u0437\u0434\u0430\u044e\u0449\u0438\u0439 \u0441\u043b\u043e\u0438 \u0438 \u0432\u043e\u043b\u043e\u043a\u0430 \u0446\u0435\u043d\u043d\u044b\u0445 \u043f\u043e\u0440\u043e\u0434, \u043f\u043e\u0434\u0447\u0435\u0440\u043a\u043d\u0435\u0442 \u043a\u0440\u0430\u0441\u043e\u0442\u0443 \u0432\u0441\u0435\u0433\u043e \u0437\u0430\u0433\u043e\u0440\u043e\u0434\u043d\u043e\u0433\u043e \u0434\u043e\u043c\u0430.<\/p>\n<p>\u0423\u0441\u043e\u0432\u0435\u0440\u0448\u0435\u043d\u0441\u0442\u0432\u043e\u0432\u0430\u043d\u0438\u0435 \u0444\u043e\u0440\u043c\u0443\u043b\u044b \u043a\u0440\u0430\u0441\u043e\u043a \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u043f\u043e\u0434\u043e\u0431\u0440\u0430\u0442\u044c \u0441\u043b\u043e\u0436\u043d\u044b\u0435 \u0441\u043e\u0447\u0435\u0442\u0430\u043d\u0438\u044f \u043e\u0442\u0442\u0435\u043d\u043a\u043e\u0432. \u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u044d\u0442\u043e\u043c\u0443 \u0441\u0435\u0433\u043e\u0434\u043d\u044f \u0441\u043b\u043e\u0432\u043e \u00ab\u0441\u0430\u0439\u0434\u0438\u043d\u0433\u00bb \u0432\u0441\u0435 \u043c\u0435\u043d\u044c\u0448\u0435 \u0438 \u043c\u0435\u043d\u044c\u0448\u0435 \u0430\u0441\u0441\u043e\u0446\u0438\u0438\u0440\u0443\u0435\u0442\u0441\u044f \u0441 \u0443\u043d\u044b\u043b\u044b\u043c\u0438 \u0436\u0435\u043b\u0442\u044b\u043c\u0438 \u0434\u0430\u0447\u0430\u043c\u0438. \u041d\u0430 \u0438\u0445 \u0441\u043c\u0435\u043d\u0443 \u043f\u0440\u0438\u0445\u043e\u0434\u044f\u0442 \u0441\u0442\u0438\u043b\u044c\u043d\u044b\u0435 \u043f\u0440\u043e\u0435\u043a\u0442\u044b \u0434\u043e\u043c\u043e\u0432 \u0432 \u0441\u043a\u0430\u043d\u0434\u0438\u043d\u0430\u0432\u0441\u043a\u043e\u043c \u0441\u0442\u0438\u043b\u0435. \u0421\u0434\u0435\u043b\u0430\u0432 \u0432\u044b\u0431\u043e\u0440 \u0432 \u043f\u043e\u043b\u044c\u0437\u0443 \u0441\u0430\u0439\u0434\u0438\u043d\u0433\u0430, \u0432\u0441\u0435 \u043d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043a\u0438, \u0441\u0432\u044f\u0437\u0430\u043d\u043d\u044b\u0435 \u0441 \u044d\u043a\u0441\u043f\u043b\u0443\u0430\u0442\u0430\u0446\u0438\u0435\u0439 \u043f\u0440\u0438\u0440\u043e\u0434\u043d\u044b\u0445 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u0432, \u043e\u0431\u043e\u0439\u0434\u0443\u0442 \u0432\u0430\u0441 \u0441\u0442\u043e\u0440\u043e\u043d\u043e\u0439.<\/p>\n<p>\u041f\u0440\u043e\u0444\u0438\u043b\u044c \u041a\u043e\u0440\u0430\u0431\u0435\u043b\u044c\u043d\u0430\u044f \u0434\u043e\u0441\u043a\u0430 \u0434\u043e\u0441\u0442\u0443\u043f\u0435\u043d \u0434\u043b\u0438\u043d\u043e\u0439: 3600 \u043c\u043c.<br \/>\n\u0412 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u0440\u0430\u0437\u043c\u0435\u0440\u043e\u0432 \u0434\u043e\u043c\u0430, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435 \u0441\u0430\u0439\u0434\u0438\u043d\u0433\u0430 \u0434\u043b\u0438\u043d\u043e\u0439 3600 \u043c\u043c \u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c \u0431\u043e\u043b\u0435\u0435 \u043e\u043f\u0442\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u043c, \u0431\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u043c\u0435\u043d\u044c\u0448\u0435\u043c\u0443 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0443 \u0441\u0442\u044b\u043a\u043e\u0432 \u043f\u0430\u043d\u0435\u043b\u0435\u0439 \u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044e \u0434\u043e\u0431\u043e\u0440\u043d\u044b\u0445 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u043e\u0432 \u0434\u043b\u044f \u043c\u043e\u043d\u0442\u0430\u0436\u0430.<br \/>\nStandart (\u0421\u0442\u0430\u043d\u0434\u0430\u0440\u0442) &#8211; \u0431\u0430\u043b\u0430\u043d\u0441 \u0432\u044b\u0441\u043e\u043a\u043e\u0433\u043e \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430 \u0438 \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e\u0439 \u0446\u0435\u043d\u044b.<br \/>\n\u041f\u0430\u043b\u0438\u0442\u0440\u0430 \u0441\u0430\u0439\u0434\u0438\u043d\u0433\u0430 \u041a\u043e\u0440\u0430\u0431\u0435\u043b\u044c\u043d\u0430\u044f \u0434\u043e\u0441\u043a\u0430 XL \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438 Classic \u0446\u0432\u0435\u0442\u043e\u0432 Standart \u0441\u043e\u0441\u0442\u043e\u0438\u0442 \u0438\u0437 5 \u043e\u0442\u0442\u0435\u043d\u043a\u043e\u0432: \u0431\u0435\u043b\u044b\u0439, \u0441\u043b\u043e\u043d\u043e\u0432\u0430\u044f \u043a\u043e\u0441\u0442\u044c, \u0432\u0430\u043d\u0438\u043b\u044c\u043d\u044b\u0439, \u0431\u0435\u0436\u0435\u0432\u044b\u0439, \u0441\u0435\u0440\u044b\u0439.<br \/>\n\u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u0448\u0438\u0440\u043e\u043a\u043e\u043c\u0443 \u0432\u044b\u0431\u043e\u0440\u0443 \u043e\u0442\u0442\u0435\u043d\u043a\u043e\u0432 \u0432\u044b \u0441\u043c\u043e\u0436\u0435\u0442\u0435 \u0440\u0435\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u0442\u044c \u043b\u044e\u0431\u044b\u0435 \u0438\u0434\u0435\u0438 \u0438 \u0432\u043e\u043f\u043b\u043e\u0442\u0438\u0442\u044c \u0432 \u0436\u0438\u0437\u043d\u044c \u0441\u0442\u0438\u043b\u044c\u043d\u044b\u0435 \u0434\u0438\u0437\u0430\u0439\u043d\u0435\u0440\u0441\u043a\u0438\u0435 \u043f\u0440\u043e\u0435\u043a\u0442\u044b. \u0420\u0430\u0437\u043d\u043e\u043e\u0431\u0440\u0430\u0437\u0438\u0435 \u0446\u0432\u0435\u0442\u043e\u0432\u043e\u0439 \u043f\u0430\u043b\u0438\u0442\u0440\u044b \u043f\u043e\u0437\u0432\u043e\u043b\u0438\u0442 \u043f\u043e\u0434\u043e\u0431\u0440\u0430\u0442\u044c \u0446\u0432\u0435\u0442 \u0441\u0430\u0439\u0434\u0438\u043d\u0433\u0430 \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u043e\u0442\u0442\u0435\u043d\u043a\u0430 \u043a\u0440\u044b\u0448\u0438 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u043e\u0432 (\u0432\u043e\u0434\u043e\u0441\u0442\u043e\u043a\u0430, \u0442\u0435\u0440\u0440\u0430\u0441\u044b, \u043e\u043a\u043e\u043d\u043d\u044b\u0445 \u043f\u0440\u043e\u0435\u043c\u043e\u0432). \u041a\u0440\u043e\u043c\u0435 \u0442\u043e\u0433\u043e, \u0446\u0432\u0435\u0442\u0430 Standart \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438 Classic \u043e\u0431\u043b\u0430\u0434\u0430\u044e\u0442 \u0432\u0441\u0435\u043c\u0438 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u043c\u0438 \u0441\u0432\u043e\u0439\u0441\u0442\u0432\u0430\u043c\u0438 \u0434\u043b\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0434\u043e\u043b\u0433\u043e\u0432\u0435\u0447\u043d\u044b\u0445 \u0438 \u043d\u0430\u0434\u0435\u0436\u043d\u044b\u0445 \u0444\u0430\u0441\u0430\u0434\u043e\u0432: \u0441\u0442\u043e\u0439\u043a\u043e\u0441\u0442\u044c\u044e \u043a \u0432\u043e\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044e \u0432\u043d\u0435\u0448\u043d\u0438\u0445 \u0444\u0430\u043a\u0442\u043e\u0440\u043e\u0432, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0441\u043e\u0445\u0440\u0430\u043d\u044f\u044e\u0442 \u0441\u0432\u043e\u0439 \u0446\u0432\u0435\u0442 \u0438 \u0432\u043d\u0435\u0448\u043d\u0438\u0439 \u0432\u0438\u0434 \u043d\u0430 \u043f\u0440\u043e\u0442\u044f\u0436\u0435\u043d\u0438\u0438 \u0434\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0438.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u041a\u043e\u0440\u0430\u0431\u0435\u043b\u044c\u043d\u0430\u044f \u0434\u043e\u0441\u043a\u0430 XL &#8211; \u043f\u0440\u043e\u0444\u0438\u043b\u044c \u0438\u043c\u0438\u0442\u0438\u0440\u0443\u044e\u0449\u0438\u0439 \u0434\u0435\u0440\u0435\u0432\u044f\u043d\u043d\u0443\u044e \u0434\u043e\u0441\u043a\u0443, \u0441 \u0443\u0432\u0435\u043b\u0438\u0447\u0435\u043d\u043d\u043e\u0439 \u0448\u0438\u0440\u0438\u043d\u043e\u0439 \u043f\u0430\u043d\u0435\u043b\u0438. \u041d\u0430\u0438\u0431\u043e\u043b\u0435\u0435 \u0440\u0430\u0441\u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0435\u043d\u043d\u0430\u044f \u0444\u043e\u0440\u043c\u0430 \u0432\u0438\u043d\u0438\u043b\u043e\u0432\u043e\u0433\u043e \u0441\u0430\u0439\u0434\u0438\u043d\u0433\u0430 \u0432 \u0420\u043e\u0441\u0441\u0438\u0438. \u0421\u043e\u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u0435 \u0434\u043b\u0438\u043d\u044b \u0438 \u0448\u0438\u0440\u0438\u043d\u044b \u043f\u0430\u043d\u0435\u043b\u0438 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0438\u0432\u0430\u0435\u0442 \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e \u043f\u043e\u043b\u0435\u0437\u043d\u0443\u044e \u043f\u043b\u043e\u0449\u0430\u0434\u044c \u0438 \u0438\u043c\u0438\u0442\u0430\u0446\u0438\u044e \u0434\u0435\u0440\u0435\u0432\u044f\u043d\u043d\u043e\u0433\u043e \u0444\u0430\u0441\u0430\u0434\u0430. \u0420\u0435\u0430\u043b\u0438\u0441\u0442\u0438\u0447\u043d\u0430\u044f \u0442\u0435\u043a\u0441\u0442\u0443\u0440\u0430 \u0441\u0430\u0439\u0434\u0438\u043d\u0433\u0430 \u0434\u043e\u0441\u0442\u043e\u