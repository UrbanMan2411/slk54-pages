\u0435\u0441\u0442\u043d\u0438\u0446\u0443 \u0431\u0443\u043a\u0432\u0430\u043b\u044c\u043d\u043e \u0434\u0432\u0443\u043c\u044f \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f\u043c\u0438.<\/p>\n<p>\t \u0422\u0440\u0438 \u0441\u043a\u043b\u0430\u0434\u043d\u044b\u0435 \u0441\u0435\u043a\u0446\u0438\u0438 \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u044b \u043f\u0440\u043e\u0447\u043d\u043e\u0439 \u043c\u0435\u0442\u0430\u043b\u043b\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0444\u0443\u0440\u043d\u0438\u0442\u0443\u0440\u043e\u0439 \u0438 \u0432\u044b\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044e\u0442 \u0432\u0435\u0441 \u0434\u043e 170 \u043a\u0433.<\/p>\n<p>\t \u0420\u0435\u043b\u044c\u0435\u0444\u043d\u0430\u044f \u043f\u043e\u0432\u0435\u0440\u0445\u043d\u043e\u0441\u0442\u044c \u0434\u0435\u0440\u0435\u0432\u044f\u043d\u043d\u044b\u0445 \u0441\u0442\u0443\u043f\u0435\u043d\u0435\u0439 \u043f\u0440\u0435\u0434\u043e\u0442\u0432\u0440\u0430\u0449\u0430\u0435\u0442 \u0441\u043a\u043e\u043b\u044c\u0436\u0435\u043d\u0438\u0435, \u0430 \u043f\u043e\u0440\u0443\u0447\u0435\u043d\u044c (\u043e\u043f\u0446\u0438\u044f) \u043f\u043e\u043c\u043e\u0433\u0430\u0435\u0442 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044c \u0440\u0430\u0432\u043d\u043e\u0432\u0435\u0441\u0438\u0435, \u043a\u043e\u0433\u0434\u0430 \u0432\u044b \u043f\u043e\u0434\u043d\u0438\u043c\u0430\u0435\u0442\u0435 \u043d\u0430 \u0447\u0435\u0440\u0434\u0430\u043a \u0441\u0435\u0437\u043e\u043d\u043d\u044b\u0439 \u0438\u043d\u0432\u0435\u043d\u0442\u0430\u0440\u044c \u0438\u043b\u0438 \u043a\u043e\u0440\u043e\u0431\u043a\u0438 \u0441 \u0432\u0435\u0449\u0430\u043c\u0438.<\/p>\n<p>\t \u041a\u0440\u044b\u0448\u043a\u0430 \u043b\u044e\u043a\u0430, \u0443\u0442\u0435\u043f\u043b\u0435\u043d\u043d\u0430\u044f \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u044b\u043c \u0441\u043b\u043e\u0435\u043c \u043f\u043e\u043b\u0438\u043f\u0440\u043e\u043f\u0438\u043b\u0435\u043d\u0430 30 \u043c\u043c, \u0438 \u043a\u043e\u0440\u043e\u0431 \u0441 \u0443\u043f\u043b\u043e\u0442\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u043c \u043a\u043e\u043d\u0442\u0443\u0440\u043e\u043c \u0437\u0430\u0449\u0438\u0449\u0430\u044e\u0442 \u0442\u0435\u043f\u043b\u043e \u0432 \u0436\u0438\u043b\u044b\u0445 \u043a\u043e\u043c\u043d\u0430\u0442\u0430\u0445 \u043e\u0442 \u0445\u043e\u043b\u043e\u0434\u043d\u043e\u0433\u043e \u0432\u043e\u0437\u0434\u0443\u0445\u0430 \u0441 \u043d\u0435\u043e\u0442\u0430\u043f\u043b\u0438\u0432\u0430\u0435\u043c\u043e\u0433\u043e \u0447\u0435\u0440\u0434\u0430\u043a\u0430.<br \/>\n,11 \u0441\u0442\u0443\u043f\u0435\u043d\u0435\u0439 \u0441{skip};\u0443\u0432\u0435\u043b\u0438\u0447\u0435\u043d\u043d\u044b\u043c \u0448\u0430\u0433\u043e\u043c \u0438{skip};\u0432\u044b\u0441\u043e\u043a\u043e \u0440\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u043d\u0430\u044f \u0432\u0435\u0440\u0445\u043d\u044f\u044f \u0441\u0442\u0443\u043f\u0435\u043d\u044c\u043a\u0430 \u0434\u0435\u043b\u0430\u044e\u0442 \u043b\u0435\u0441\u0442\u043d\u0438\u0446\u0443 \u0443\u0434\u043e\u0431\u043d\u043e\u0439 \u0434\u043b\u044f \u043f\u043e\u0434\u044a\u0451\u043c\u0430<br \/>\n,\u041a\u0440\u044b\u0448\u043a\u0430 \u043b\u044e\u043a\u0430 \u043e\u0431\u0440\u0430\u043c\u043b\u044f\u0435\u0442\u0441\u044f \u043c\u0435\u0442\u0430\u043b\u043b\u0438\u0447\u0435\u0441\u043a\u0438\u043c\u0438 \u0443\u0433\u043e\u043b\u043a\u0430\u043c\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0443\u0441\u0438\u043b\u0438\u0432\u0430\u044e\u0442 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u044e \u043b\u0435\u0441\u0442\u043d\u0438\u0446\u044b \u0438{skip};\u043d\u0435{skip};\u0434\u0430\u044e\u0442 \u0435\u0439{skip};\u043f\u0435\u0440\u0435\u043a\u0430\u0448\u0438\u0432\u0430\u0442\u044c\u0441\u044f. \u0422\u043e\u043b\u0449\u0438\u043d\u0430 \u0441\u0442\u0443\u043f\u0435\u043d\u0435\u0439 \u0443\u0432\u0435\u043b\u0438\u0447\u0435\u043d\u0430 \u0434\u043e{skip};22{skip};\u043c\u043c (\u043f\u043e{skip};\u0441\u0440\u0430\u0432\u043d\u0435\u043d\u0438\u044e \u0441{skip};20{skip};\u043c\u043c \u0443{skip};\u0430\u043d\u0430\u043b\u043e\u0433\u0438\u0447\u043d\u044b\u0445 \u043b\u0435\u0441\u0442\u043d\u0438\u0446)<br \/>\n,\u0414\u0440\u0435\u0432\u0435\u0441\u0438\u043d\u0430 \u0445\u0432\u043e\u0439\u043d\u044b\u0445 \u043f\u043e\u0440\u043e\u0434 \u0438{skip};\u0431\u0435\u043b\u044b\u0439 \u043b\u044e\u043a \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u044e\u0442 \u043b\u0435\u0441\u0442\u043d\u0438\u0446\u0435 \u0432\u043f\u0438\u0441\u0430\u0442\u044c\u0441\u044f \u0432{skip};\u043b\u044e\u0431\u043e\u0439 \u0438\u043d\u0442\u0435\u0440\u044c\u0435\u0440. \u0412{skip};\u0441\u043b\u043e\u0436\u0435\u043d\u043d\u043e\u043c \u0432\u0438\u0434\u0435 \u043b\u0435\u0441\u0442\u043d\u0438\u0446\u0430 \u043d\u0435{skip};\u0437\u0430\u043d\u0438\u043c\u0430\u0435\u0442 \u043c\u043d\u043e\u0433\u043e \u043c\u0435\u0441\u0442\u0430, \u0430{skip};\u043a\u0440\u044b\u0448\u043a\u0430 \u043b\u044e\u043a\u0430 \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0441\u044f \u043f\u043e\u0447\u0442\u0438 \u043d\u0435\u0437\u0430\u043c\u0435\u0442\u043d\u0430<br \/>\n,\u0414\u043b\u044f \u043c\u043e\u043d\u0442\u0430\u0436\u0430 \u043b\u0435\u0441\u0442\u043d\u0438\u0446 \u043d\u0435{skip};\u0442\u0440\u0435\u0431\u0443\u044e\u0442\u0441\u044f \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u044b\u0435 \u043d\u0430\u0432\u044b\u043a\u0438, \u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e \u0438\u0437\u0443\u0447\u0438\u0442\u044c \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u044e. \u041a{skip};\u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u043e\u0439 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0442\u0430\u0446\u0438\u0438 \u043c\u043e\u0436\u043d\u043e \u0434\u043e\u0431\u0430\u0432\u0438\u0442\u044c \u043f\u043e\u0440\u0443\u0447\u043d\u0438 \u