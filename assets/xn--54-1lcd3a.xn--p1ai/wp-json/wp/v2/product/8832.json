30\u043d\u043d\u044b\u0439 \u0431\u0438\u0442\u0443\u043c, \u0430 \u043d\u0435 \u043e\u043a\u0438\u0441\u043b\u0435\u043d\u043d\u044b\u0439, \u043a\u0430\u043a \u0432 \u0431\u044e\u0434\u0436\u0435\u0442\u043d\u044b\u0445 \u0441\u0435\u0440\u0438\u044f\u0445. \u0422\u0430\u043a\u043e\u0439 \u0431\u0438\u0442\u0443\u043c \u0437\u0430\u043c\u0435\u0442\u043d\u043e \u043f\u0440\u043e\u0434\u043b\u0435\u0432\u0430\u0435\u0442 \u0441\u0440\u043e\u043a \u0441\u043b\u0443\u0436\u0431\u044b \u0433\u0438\u0431\u043a\u043e\u0439 \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u044b, \u0430 \u043c\u043e\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0435\u0451 \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0441\u044f \u0433\u043e\u0440\u0430\u0437\u0434\u043e \u0443\u0434\u043e\u0431\u043d\u0435\u0435.<br \/>\n\u041d\u0430\u0434\u0435\u0436\u043d\u043e\u0435 \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u0435<br \/>\n\u0421\u0435\u043a\u0440\u0435\u0442 \u0441\u0432\u0435\u0440\u0445\u043f\u0440\u043e\u0447\u043d\u043e\u0433\u043e \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u044f \u0433\u043e\u043d\u0442\u043e\u0432 \u043c\u0435\u0436\u0434\u0443 \u0441\u043e\u0431\u043e\u0439 \u0432 \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0435 \u043c\u043e\u043d\u0442\u0430\u0436\u0430 \u0437\u0430\u043a\u043b\u044e\u0447\u0430\u0435\u0442\u0441\u044f \u0432 \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u043e\u043c \u043a\u043b\u0435\u0435\u0432\u043e\u043c \u0437\u0430\u043c\u043a\u0435 \u043f\u043e\u0434 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435\u043c \u0431\u0438\u0442\u0443\u043c\u043d\u0430\u044f \u0441\u0432\u0430\u0440\u043a\u0430 \u0433\u043e\u043d\u0442\u043e\u0432. \u0421\u0446\u0435\u043f\u043b\u0435\u043d\u0438\u0435 \u043f\u0440\u043e\u0438\u0441\u0445\u043e\u0434\u0438\u0442 \u043d\u0430 \u043c\u043e\u043b\u0435\u043a\u0443\u043b\u044f\u0440\u043d\u043e\u043c \u0443\u0440\u043e\u0432\u043d\u0435, \u0442\u0430\u043a\u043e\u043c\u0443 \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u044e \u043d\u0435 \u0441\u0442\u0440\u0430\u0448\u043d\u044b \u0441\u0430\u043c\u044b\u0435 \u0441\u0438\u043b\u044c\u043d\u044b\u0435 \u043f\u043e\u0440\u044b\u0432\u044b \u0432\u0435\u0442\u0440\u0430.<br \/>\n\u041d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435<br \/>\n\u0413\u0438\u0431\u043a\u043e\u0439 \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u0435\u0439 \u043f\u043e\u043a\u0440\u044b\u0432\u0430\u044e\u0442 \u043a\u0440\u043e\u0432\u043b\u044e \u0441 \u0443\u043a\u043b\u043e\u043d\u043e\u043c \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 12 \u0433\u0440\u0430\u0434\u0443\u0441\u043e\u0432. \u0412 \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438 \u0416\u0435\u043d\u0435\u0432\u0430 \u0444\u043e\u0440\u043c\u0430 \u043d\u0430\u0440\u0435\u0437\u043a\u0438 \u0433\u043e\u043d\u0442\u0430 \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u044b \u043d\u0430\u0437\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0441\u043b\u0430\u043d\u0435\u0446, \u043a\u043e\u044d\u0444\u0444\u0438\u0446\u0438\u0435\u043d\u0442 \u043f\u0435\u0440\u0435\u0445\u043b\u0435\u0441\u0442\u0430 \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 2,35, \u043a\u043e\u044d\u0444\u0444\u0438\u0446\u0438\u0435\u043d\u0442 \u0432\u044b\u0448\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0432 \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438 \u0421\u0430\u043f\u043f\u043e\u0440\u043e. \u0412\u0441\u0435\u0433\u043e \u0432 \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438 6 \u0446\u0432\u0435\u0442\u043e\u0432, \u0441\u0440\u0435\u0434\u0438 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0443\u043d\u0438\u0432\u0435\u0440\u0441\u0430\u043b\u044c\u043d\u044b\u0439 \u043e\u0442\u0442\u0435\u043d\u043e\u043a \u0441\u0435\u0440\u043e\u0433\u043e \u00ab\u0424\u043b\u0430\u0434\u0435\u043d\u00bb.<br \/>\n\u041f\u043e\u0441\u044b\u043f\u043a\u0430 \u0438\u0437 \u0431\u0430\u0437\u0430\u043b\u044c\u0442\u0430<br \/>\n\u0411\u0430\u0437