{"id":5373,"date":"2023-05-01T13:21:58","date_gmt":"2023-05-01T06:21:58","guid":{"rendered":"http:\/\/slk54.ru\/?post_type=product&#038;p=5373"},"modified":"2023-06-19T19:22:31","modified_gmt":"2023-06-19T12:22:31","slug":"%d0%b3%d0%bb%d0%b0%d0%b2%d1%80%d0%be%d1%81%d1%82%d0%b5%d0%bf%d0%bb%d0%be-%d0%bb%d0%b0%d0%b9%d1%82-2-1000%d1%85600%d1%85100","status":"publish","type":"product","link":"https:\/\/xn--54-1lcd3a.xn--p1ai\/product\/%d0%b3%d0%bb%d0%b0%d0%b2%d1%80%d0%be%d1%81%d1%82%d0%b5%d0%bf%d0%bb%d0%be-%d0%bb%d0%b0%d0%b9%d1%82-2-1000%d1%85600%d1%85100\/","title":{"rendered":"\u0413\u041b\u0410\u0412\u0420\u041e\u0421\u0422\u0415\u041f\u041b\u041e \u041b\u0430\u0439\u0442 2 1000\u0445600\u0445100"},"content":{"rendered":"<p>\u0413\u041b\u0410\u0412\u0420\u041e\u0421\u0422\u0415\u041f\u041b\u041e &#8211; \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u044b\u0439 \u0438 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u044b\u0439 \u0443\u0442\u0435\u043f\u043b\u0438\u0442\u0435\u043b\u044c \u0434\u043b\u044f \u043a\u043e\u0442\u0442\u0435\u0434\u0436\u043d\u043e\u0433\u043e \u0434\u043e\u043c\u043e\u0441\u0442\u0440\u043e\u0435\u043d\u0438\u044f.<\/p>\n<p>\u041b\u0451\u0433\u043a\u0438\u0435 \u043d\u0435\u0433\u043e\u0440\u044e\u0447\u0438\u0435 \u043f\u043b\u0438\u0442\u044b \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 \u0433\u043e\u0440\u043d\u044b\u0445 \u043f\u043e\u0440\u043e\u0434 \u0431\u0430\u0437\u0430\u043b\u044c\u0442\u043e\u0432\u043e\u0439 \u0433\u0440\u0443\u043f\u043f\u044b, \u043f\u0440\u0435\u0434\u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044b\u0435 \u0434\u043b\u044f \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u0442\u0435\u043f\u043b\u043e &#8211; \u0438 \u0437\u0432\u0443\u043a\u043e\u0438\u0437\u043e\u043b\u044f\u0446\u0438\u0438 \u0432 \u043d\u0435 \u043d\u0430\u0433\u0440\u0443\u0436\u0430\u0435\u043c\u044b\u0445 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u044f\u0445.<\/p>\n<p>\u041d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435:<br \/>\n\u2022 \u041f\u0440\u0435\u0434\u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d \u0434\u043b\u044f \u0448\u0443\u043c\u043e-\u0438 \u0442\u0435\u043f\u043b\u043e\u0438\u0437\u043e\u043b\u044f\u0446\u0438\u0438 \u043d\u0435 \u043d\u0430\u0433\u0440\u0443\u0436\u0430\u0435\u043c\u044b\u0445 \u0441\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0439 \u2013 \u0441\u043a\u0430\u0442\u043d\u044b\u0435 \u043a\u0440\u043e\u0432\u043b\u0438, \u0441\u0442\u0435\u043d\u044b, \u043c\u0430\u043d\u0441\u0430\u0440\u0434\u044b, \u0447\u0435\u0440\u0434\u0430\u0447\u043d\u044b\u0435 \u043f\u0435\u0440\u0435\u043a\u0440\u044b\u0442\u0438\u044f, \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u0435 \u043f\u0435\u0440\u0435\u0433\u043e\u0440\u043e\u0434\u043a\u0438, \u043f\u043e\u043b\u044b \u043f\u043e \u043b\u0430\u0433\u0430\u043c;<br \/>\n\u2022 \u041f\u0440\u0438\u043c\u0435\u043d\u044f\u0435\u0442\u0441\u044f \u0434\u043b\u044f \u0443\u0442\u0435\u043f\u043b\u0435\u043d\u0438\u044f \u0432\u0435\u043d\u0442\u0438\u043b\u044f\u0446\u0438\u043e\u043d\u043d\u044b\u0445 \u0438 \u043e\u0442\u043e\u043f\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u0441\u0438\u0441\u0442\u0435\u043c, \u0440\u0435\u0437\u0435\u0440\u0432\u0443\u0430\u0440\u043e\u0432, \u0442\u0440\u0443\u0431\u043e\u043f\u0440\u043e\u0432\u043e\u0434\u043e\u0432, \u0432\u043e\u0437\u0434\u0443\u0445\u043e\u0432\u043e\u0434\u043e\u0432 \u0438 \u043f\u0440\u043e\u043c\u044b\u0448\u043b\u0435\u043d\u043d\u043e\u0433\u043e \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u044f;<br \/>\n\u2022 \u041f\u043e\u0434\u0445\u043e\u0434\u0438\u0442 \u0434\u043b\u044f \u043a\u043e\u0442\u0442\u0435\u0434\u0436\u043d\u043e\u0433\u043e \u0434\u043e\u043c\u043e\u0441\u0442\u0440\u043e\u0435\u043d\u0438\u044f.<\/p>\n<p>\u041f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430:<br \/>\n\u2022 \u0414\u043e\u043b\u0433\u043e\u0432\u0435\u0447\u043d\u043e\u0441\u0442\u044c (\u043f\u043b\u0438\u0442\u044b \u0438\u043c\u0435\u044e\u0442 \u043f\u043b\u043e\u0442\u043d\u043e\u0441\u0442\u044c 25 \u043a\u0433\/\u043c3, \u0438\u0437\u043d\u043e\u0441\u043e\u0441\u0442\u043e\u0439\u043a\u0438\u0435, \u0431\u0438\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438 \u0443\u0441\u0442\u043e\u0439\u0447\u0438\u0432\u044b \u2013 \u043d\u0435 \u043f\u043e\u0434\u0432\u0435\u0440\u0433\u0430\u044e\u0442\u0441\u044f \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u044e \u043a\u043e\u0440\u0440\u043e\u0437\u0438\u0435\u0439, \u0433\u0440\u0438\u0431\u043a\u043e\u043c, \u043f\u043b\u0435\u0441\u0435\u043d\u044c\u044e \u0438 \u0433\u0440\u044b\u0437\u0443\u043d\u0430\u043c\u0438; \u0441\u043e\u0445\u0440\u0430\u043d\u044f\u044e\u0442 \u0444\u043e\u0440\u043c\u0443 \u0438 \u043d\u0435 \u0434\u0430\u044e\u0442 \u0443\u0441\u0430\u0434\u043a\u0438 \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u0432\u0441\u0435\u0433\u043e \u043f\u0435\u0440\u0438\u043e\u0434\u0430 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f; \u0438\u043c\u0435\u044e\u0442 \u0434\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043f\u0435\u0440\u0438\u043e\u0434 \u044d\u043a\u0441\u043f\u043b\u0443\u0430\u0442\u0430\u0446\u0438\u0438);<br \/>\n\u2022 \u042d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c (\u0443\u0442\u0435\u043f\u043b\u0438\u0442\u0435\u043b\u044c \u0445\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u0438\u0437\u0443\u0435\u0442 \u0432\u044b\u0441\u043e\u043a\u0438\u043c\u0438 \u0448\u0443\u043c\u043e- \u0438 \u0442\u0435\u043f\u043b\u043e\u0438\u0437\u043e\u043b\u044f\u0446\u0438\u043e\u043d\u043d\u044b\u043c\u0438 \u0441\u0432\u043e\u0439\u0441\u0442\u0432\u0430\u043c\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u043f\u043e\u0441\u043e\u0431\u0441\u0442\u0432\u0443\u044e\u0442 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044e \u0438 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u044e \u0431\u043b\u0430\u0433\u043e\u043f\u0440\u0438\u044f\u0442\u043d\u043e\u0433\u043e \u043c\u0438\u043a\u0440\u043e\u043a\u043b\u0438\u043c\u0430\u0442\u0430 \u0432 \u043f\u043e\u043c\u0435\u0449\u0435\u043d\u0438\u0438);<br \/>\n\u2022 \u0411\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u044c (\u043f\u043b\u0438\u0442\u044b \u0438\u0437\u0433\u043e\u0442\u043e\u0432\u043b\u0435\u043d\u044b \u0438\u0437 \u044d\u043a\u043e\u043b\u043e\u0433\u0438\u0447\u043d\u044b\u0445 \u043a\u043e\u043c\u043f\u043e\u043d\u0435\u043d\u0442\u043e\u0432, \u043d\u0435 \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u0442 \u0438 \u043d\u0435 \u0432\u044b\u0434\u0435\u043b\u044f\u044e\u0442 \u0432 \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0435 \u044d\u043a\u0441\u043f\u043b\u0443\u0430\u0442\u0430\u0446\u0438\u0438 \u0432\u0440\u0435\u0434\u043d\u044b\u0435 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0430; \u043e\u0442\u043d\u043e\u0441\u044f\u0442\u0441\u044f \u043a \u0433\u0440\u0443\u043f\u043f\u0435 \u043d\u0435\u0433\u043e\u0440\u044e\u0447\u0438\u0445 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u0432);<br \/>\n\u2022 \u0423\u0434\u043e\u0431\u043d\u043e\u0435 \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u0435 (\u0431\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u043d\u0435\u0431\u043e\u043b\u044c\u0448\u043e\u043c\u0443 \u0432\u0435\u0441\u0443 \u043f\u043b\u0438\u0442 \u0441\u043e\u0437\u0434\u0430\u0435\u0442\u0441\u044f \u043d\u0435\u0431\u043e\u043b\u044c\u0448\u0430\u044f \u043d\u0430\u0433\u0440\u0443\u0437\u043a\u0430 \u043d\u0430 \u043a\u0430\u0440\u043a\u0430\u0441 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0439; \u043b\u0435\u0433\u043a\u0438\u0439 \u0438 \u0431\u044b\u0441\u0442\u0440\u044b\u0439 \u043c\u043e\u043d\u0442\u0430\u0436 \u2013 \u043f\u043b\u0438\u0442\u044b \u043f\u043b\u043e\u0442\u043d\u043e \u043f\u0440\u0438\u043b\u0435\u0433\u0430\u044e\u0442 \u043a \u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0438\u044e; \u0432\u043e\u0437\u043c\u043e\u0436\u0435\u043d \u043c\u043e\u043d\u0442\u0430\u0436, \u043a\u0430\u043a \u0432 \u0433\u043e\u0440\u0438\u0437\u043e\u043d\u0442\u0430\u043b\u044c\u043d\u043e\u043c, \u0442\u0430\u043a \u0438 \u0432\u0435\u0440\u0442\u0438\u043a\u0430\u043b\u044c\u043d\u043e\u043c \u043f\u043e\u043b\u043e\u0436\u0435\u043d\u0438\u0438; \u0443\u043f\u0430\u043a\u043e\u0432\u0430\u043d\u044b \u0432 \u043f\u043e\u043b\u0438\u044d\u0442\u0438\u043b\u0435\u043d\u043e\u0432\u0443\u044e \u043f\u043b\u0435\u043d\u043a\u0443 \u2013 \u0434\u043b\u044f \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u044f \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u0430 \u0432 \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0435 \u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u0438\u0440\u043e\u0432\u043e\u043a \u0438 \u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0438; \u043f\u0440\u0438 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0441\u0442\u0438 \u0440\u0435\u0436\u0435\u0442\u0441\u044f \u043f\u0440\u0438 \u043f\u043e\u043c\u043e\u0449\u0438 \u043d\u043e\u0436\u0430 \u043f\u043e \u0440\u0430\u0437\u043c\u0435\u0440\u0430\u043c).<\/p>\n<p>\u0420\u0415\u041a\u041e\u041c\u0415\u041d\u0414\u0410\u0426\u0418\u0418:<br \/>\n\u2022 \u041f\u0440\u0438 \u0440\u0430\u0431\u043e\u0442\u0435 \u0441 \u0443\u0442\u0435\u043f\u043b\u0438\u0442\u0435\u043b\u0435\u043c \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 \u0438\u043d\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043b\u044c\u043d\u044b\u0435 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430 \u0437\u0430\u0449\u0438\u0442\u044b;<br \/>\n\u2022 \u041e\u0442\u043a\u0440\u044b\u0432\u0430\u0442\u044c \u043f\u043b\u0438\u0442\u044b \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u0442\u0441\u044f \u043d\u0435\u043f\u043e\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043d\u043d\u043e \u043f\u0435\u0440\u0435\u0434 \u043c\u043e\u043d\u0442\u0430\u0436\u043e\u043c, \u0447\u0442\u043e\u0431\u044b \u043d\u0435 \u0434\u043e\u043f\u0443\u0441\u0442\u0438\u0442\u044c \u0438\u0445 \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u043e\u0433\u043e \u043f\u043e\u0432\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u044f;<br \/>\n\u2022 \u0415\u0441\u043b\u0438 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043d\u0430\u0440\u0435\u0437\u043a\u0430 \u0443\u0442\u0435\u043f\u043b\u0438\u0442\u0435\u043b\u044f, \u0442\u043e \u0435\u0435 \u0441\u043b\u0435\u0434\u0443\u0435\u0442 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0438\u0442\u044c \u043d\u0430 \u0442\u0432\u0435\u0440\u0434\u043e\u0439 \u043f\u043e\u0432\u0435\u0440\u0445\u043d\u043e\u0441\u0442\u0438 \u043f\u0440\u0438 \u043f\u043e\u043c\u043e\u0449\u0438 \u0434\u043b\u0438\u043d\u043d\u043e\u0433\u043e \u043e\u0441\u0442\u0440\u043e\u0433\u043e \u043d\u043e\u0436\u0430, \u0447\u0442\u043e\u0431\u044b \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044c \u043f\u043e\u0432\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u044f \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u0430 \u0438 \u0441\u043d\u0438\u0436\u0435\u043d\u0438\u044f \u0435\u0433\u043e \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430;<br \/>\n\u2022 \u041f\u0440\u0438 \u043c\u043e\u043d\u0442\u0430\u0436\u0435 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u0441\u043b\u0435\u0434\u0438\u0442\u044c, \u0447\u0442\u043e\u0431\u044b \u0442\u0435\u043f\u043b\u043e\u0438\u0437\u043e\u043b\u044f\u0446\u0438\u043e\u043d\u043d\u044b\u0435 \u043f\u043b\u0438\u0442\u044b \u043f\u043b\u043e\u0442\u043d\u043e \u043f\u0440\u0438\u043b\u0435\u0433\u0430\u043b\u0438 \u043a \u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0438\u044e, \u043d\u0435 \u043e\u0431\u0440\u0430\u0437\u0443\u044f \u0449\u0435\u043b\u0438 \u0438 \u043c\u043e\u0441\u0442\u0438\u043a\u0438 \u0445\u043e\u043b\u