44b\u0433\u043b\u044f\u0434\u0435\u0442\u044c \u044d\u0444\u0444\u0435\u043a\u0442\u043d\u043e \u0438 \u043e\u0440\u0438\u0433\u0438\u043d\u0430\u043b\u044c\u043d\u043e.<\/p>\n<p>\u0418\u043c\u0438\u0442\u0438\u0440\u0443\u0435\u0442 \u043e\u0442\u0434\u0435\u043b\u043a\u0443 \u043d\u0430\u0442\u0443\u0440\u0430\u043b\u044c\u043d\u044b\u043c \u043a\u0430\u043c\u043d\u0435\u043c<br \/>\n\u041a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u044f ROCKY \u043f\u0435\u0440\u0435\u0434\u0430\u0435\u0442 \u0440\u0435\u043b\u044c\u0435\u0444 \u0438 \u0444\u0430\u043a\u0442\u0443\u0440\u0443 \u0441\u043b\u043e\u0438\u0441\u0442\u043e\u0433\u043e \u043f\u0435\u0441\u0447\u0430\u043d\u0438\u043a\u0430. \u0421\u043e\u0447\u0435\u0442\u0430\u043d\u0438\u0435 \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u0433\u043e \u0446\u0432\u0435\u0442\u0430 \u0438 \u043e\u0442\u0442\u0435\u043d\u043a\u043e\u0432 \u043d\u0430 \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u044b\u0445 \u0444\u0440\u0430\u0433\u043c\u0435\u043d\u0442\u0430\u0445 \u0438 \u0448\u0432\u0430\u0445 \u043f\u043e\u0434\u043e\u0431\u0440\u0430\u043d\u043e \u043d\u0430\u0441\u0442\u043e\u043b\u044c\u043a\u043e \u0442\u043e\u0447\u043d\u043e, \u0447\u0442\u043e \u0434\u043e\u043c, \u043e\u0442\u0434\u0435\u043b\u0430\u043d\u043d\u044b\u0439 \u044d\u0442\u0438\u043c \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u043c, \u043d\u0435\u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u043e\u0442\u043b\u0438\u0447\u0438\u0442\u044c \u043e\u0442 \u043a\u0430\u043c\u0435\u043d\u043d\u043e\u0433\u043e \u0434\u0430\u0436\u0435 \u0441 \u0431\u043b\u0438\u0437\u043a\u043e\u0433\u043e \u0440\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u044f.<\/p>\n<p>\u0418\u0434\u0435\u0430\u043b\u044c\u043d\u043e \u0432\u044b\u0433\u043b\u044f\u0434\u0438\u0442<br \/>\n\u0421\u043b\u043e\u0436\u043d\u044b\u0439 \u0433\u043b\u0443\u0431\u043e\u043a\u0438\u0439 \u0440\u0435\u043b\u044c\u0435\u0444 \u0441 \u0442\u0449\u0430\u0442\u0435\u043b\u044c\u