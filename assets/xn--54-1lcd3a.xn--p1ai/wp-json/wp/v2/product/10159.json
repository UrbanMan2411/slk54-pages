{"id":10159,"date":"2024-05-16T15:54:17","date_gmt":"2024-05-16T08:54:17","guid":{"rendered":"https:\/\/xn--54-1lcd3a.xn--p1ai\/product\/%d0%b2%d0%b8%d0%bd%d0%b8%d0%bb%d0%be%d0%b2%d1%8b%d0%b5-%d1%81%d0%be%d1%84%d0%b8%d1%82%d1%8b-estetic-classic\/"},"modified":"2024-05-20T11:34:35","modified_gmt":"2024-05-20T04:34:35","slug":"%d0%b2%d0%b8%d0%bd%d0%b8%d0%bb%d0%be%d0%b2%d1%8b%d0%b5-%d1%81%d0%be%d1%84%d0%b8%d1%82%d1%8b-estetic-classic","status":"publish","type":"product","link":"https:\/\/xn--54-1lcd3a.xn--p1ai\/product\/%d0%b2%d0%b8%d0%bd%d0%b8%d0%bb%d0%be%d0%b2%d1%8b%d0%b5-%d1%81%d0%be%d1%84%d0%b8%d1%82%d1%8b-estetic-classic\/","title":{"rendered":"\u0412\u0438\u043d\u0438\u043b\u043e\u0432\u044b\u0435 \u0441\u043e\u0444\u0438\u0442\u044b Estetic Classic"},"content":{"rendered":"<p>\u0421\u043e\u0444\u0438\u0442 Estetic &#8211; \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0435 \u043f\u0430\u043d\u0435\u043b\u0438 \u0434\u043b\u044f \u043e\u0444\u043e\u0440\u043c\u043b\u0435\u043d\u0438\u044f \u043a\u0430\u0440\u043d\u0438\u0437\u043d\u043e\u0433\u043e \u0438 \u0444\u0440\u043e\u043d\u0442\u043e\u043d\u043d\u043e\u0433\u043e \u0441\u0432\u0435\u0441\u043e\u0432 \u043a\u0440\u043e\u0432\u043b\u0438, \u043f\u043e\u0442\u043e\u043b\u043a\u0430 \u0442\u0435\u0440\u0440\u0430\u0441\u044b \u0438 \u043a\u0440\u044b\u043b\u044c\u0446\u0430. \u041e\u0441\u043e\u0431\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u0441\u043e\u0444\u0438\u0442\u043e\u0432 Estetic &#8211; \u0441\u043a\u0440\u044b\u0442\u0430\u044f \u043f\u0435\u0440\u0444\u043e\u0440\u0430\u0446\u0438\u044f, \u043d\u0430\u043d\u043e\u0441\u0438\u043c\u0430\u044f \u043d\u0430 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0435 \u0440\u0435\u0431\u0440\u0430 \u0436\u0435\u0441\u0442\u043a\u043e\u0441\u0442\u0438, \u0441\u043f\u0440\u044f\u0442\u0430\u043d\u043d\u044b\u0435 \u043f\u043e\u0434 \u043f\u043e\u0432\u0435\u0440\u0445\u043d\u043e\u0441\u0442\u044c\u044e \u0441\u043e\u0444\u0438\u0442\u0430. \u042d\u0442\u043e \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u043f\u043e\u0432\u044b\u0441\u0438\u0442\u044c \u0432\u0435\u043d\u0442\u0438\u043b\u0438\u0440\u0443\u0435\u043c\u043e\u0441\u0442\u044c \u043f\u043e\u0434\u043a\u0440\u043e\u0432\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0430, \u043d\u0435 \u043d\u0430\u0440\u0443\u0448\u0438\u0432 \u044d\u0441\u0442\u0435\u0442\u0438\u0447\u043d\u043e\u0441\u0442\u0438 \u0432\u043d\u0435\u0448\u043d\u0435\u0433\u043e \u0432\u0438\u0434\u0430. \u041a\u0440\u043e\u043c\u0435 \u0442\u043e\u0433\u043e, \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f \u0441\u043e\u0444\u0438\u0442\u0430 \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u0441\u043a\u0440\u044b\u0442\u044c \u043c\u0435\u0441\u0442\u0430 \u0441\u0442\u044b\u043a\u043e\u0432. \u0413\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f \u0441\u043e\u0444\u0438\u0442\u043e\u0432 \u0441\u043f\u043e\u0441\u043e\u0431\u0441\u0442\u0432\u0443\u0435\u0442 \u043f\u0440\u043e\u0441\u0442\u043e\u043c\u0443 \u0438 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u043c\u0443 \u043c\u043e\u043d\u0442\u0430\u0436\u0443.<\/p>\n<p>\u0421\u043e\u0444\u0438\u0442 Estetic:<br \/>\n\u0441\u043a\u0440\u044b\u0442\u0430\u044f \u043f\u0435\u0440\u0444\u043e\u0440\u0430\u0446\u0438\u044f<br \/>\n\u044d\u0441\u0442\u0435\u0442\u0438\u0447\u043d\u044b\u0439 \u0432\u043d\u0435\u0448\u043d\u0438\u0439 \u0432\u0438\u0434<br \/>\n\u043f\u043e\u0432\u044b\u0448\u0435\u043d\u043d\u0430\u044f \u0432\u0435\u043d\u0442\u0438\u043b\u0438\u0440\u0443\u0435\u043c\u043e\u0441\u0442\u044c \u043f\u043e\u0434\u043a\u0440\u043e\u0432\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0430<br \/>\n\u043d\u0435 \u0432\u0438\u0434\u043d\u044b \u0441\u0442\u044b\u043a\u0438 \u043c\u0435\u0436\u0434\u0443 \u043f\u0430\u043d\u0435\u043b\u044f\u043c\u0438<\/p>\n<p>\u041a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u044f Classic (\u041a\u043b\u0430\u0441\u0441\u0438\u043a\u0430) \u2013 \u0431\u0430\u043b\u0430\u043d\u0441 \u0432\u044b\u0441\u043e\u043a\u043e\u0433\u043e \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430 \u0438 \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e\u0439 \u0446\u0435\u043d\u044b.<br \/>\n\u041f\u0430\u043b\u0438\u0442\u0440\u0430 \u0441\u043e\u0444\u0438\u0442\u0430 Estetic \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438 \u0441\u043e\u0441\u0442\u043e\u0438\u0442 \u0438\u0437 2 \u043e\u0442\u0442\u0435\u043d\u043a\u043e\u0432: \u0431\u0435\u043b\u044b\u0439, \u043a\u043e\u0440\u0438\u0447\u043d\u0435\u0432\u044b\u0439.<br \/>\n\u0422\u0435\u043a\u0441\u0442\u0443\u0440\u0430 \u0434\u0435\u0440\u0435\u0432\u0430 \u043d\u0430 \u043f\u0430\u043d\u0435\u043b\u044f\u0445 \u0441\u043e\u0444\u0438\u0442\u0430 \u0438\u043c\u0438\u0442\u0438\u0440\u0443\u0435\u0442 \u0444\u0430\u043a\u0442\u0443\u0440\u0443 \u043d\u0430\u0442\u0443\u0440\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0441\u0440\u0443\u0431\u0430. \u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u044d\u0442\u043e\u043c\u0443, \u0432\u043d\u0435\u0448\u043d\u0438\u0439 \u0432\u0438\u0434 \u0434\u043e\u043c\u0430 \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0441\u044f \u0431\u043e\u043b\u0435\u0435 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u043c \u0438 \u043e\u0440\u0433\u0430\u043d\u0438\u0447\u043d\u044b\u043c.  \u0421\u043e\u0444\u0438\u0442\u044b Classic \u043e\u0431\u043b\u0430\u0434\u0430\u044e\u0442 \u0432\u0441\u0435\u043c\u0438 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u043c\u0438 \u0441\u0432\u043e\u0439\u0441\u0442\u0432\u0430\u043c\u0438 \u0434\u043b\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0434\u043e\u043b\u0433\u043e\u0432\u0435\u0447\u043d\u044b\u0445 \u0438 \u043d\u0430\u0434\u0435\u0436\u043d\u044b\u0445 \u043f\u0440\u043e\u0435\u043a\u0442\u043e\u0432: \u0441\u0442\u043e\u0439\u043a\u043e\u0441\u0442\u044c\u044e \u043a \u0432\u043e\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044e \u0432\u043d\u0435\u0448\u043d\u0438\u0445 \u0444\u0430\u043a\u0442\u043e\u0440\u043e\u0432, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0441\u043e\u0445\u0440\u0430\u043d\u044f\u044e\u0442 \u0441\u0432\u043e\u0439 \u0446\u0432\u0435\u0442 \u0438 \u0432\u043d\u0435\u0448\u043d\u0438\u0439 \u0432\u0438\u0434 \u043d\u0430 \u043f\u0440\u043e\u0442\u044f\u0436\u0435\u043d\u0438\u0438 \u0434\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0438.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u0414\u043b\u0438\u043d\u0430\t3000 \u043c\u043c<br \/>\n\u0428\u0438\u0440\u0438\u043d\u0430 \u043e\u0431\u0449\u0430\u044f\t285 \u043c\u043c<br \/>\n\u0428\u0438\u0440\u0438\u043d\u0430 \u0440\u0430\u0431\u043e\u0447\u0435\u0439 \u043f\u043e\u0432\u0435\u0440\u0445\u043d\u043e\u0441\u0442\u0438\t246 \u043c\u043c<br \/>\n\u041f\u043e\u043b\u0435\u0437\u043d\u0430\u044f \u043f\u043b\u043e\u0449\u0430\u0434\u044c \u043f\u0430\u043d\u0435\u043b\u0438\t0,74 \u043c\u00b2<br \/>\n\u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0432 \u0443\u043f\u0430\u043a\u043e\u0432\u043a\u0435\t22 \u0448\u0442.<\/p>\n","protected":false},"featured_media":10157,"template":"","meta":[],"product_cat":[116,90,83],"product_tag":[],"class_list":["post-10159","product","type-product","status-publish","has-post-thumbnail","hentry","product_cat-grand-line-vinyl-siding","product_cat-vinyl-siding","product_cat-siding"],"_links":{"self":[{"href":"https:\/\/xn--54-1lcd3a.xn--p1ai\/wp-json\/wp\/v2\/product\/10159","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/xn--54-1lcd3a.xn--p1ai\/wp-json\/wp\/v2\/product"}],"about":[{"href":"https:\/\/