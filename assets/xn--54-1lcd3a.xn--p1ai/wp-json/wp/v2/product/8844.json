0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435\u043c \u043e\u043a\u0438\u0441\u043b\u0435\u043d\u043d\u043e\u0433\u043e \u0431\u0438\u0442\u0443\u043c\u0430. \u0421\u0440\u043e\u043a \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0438 \u043d\u0430 \u0442\u0430\u043a\u0443\u044e \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u0443 \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 \u0446\u0435\u043b\u044b\u0445 50 \u043b\u0435\u0442.<br \/>\n\u041d\u0430\u0434\u0435\u0436\u043d\u043e\u0435 \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u0435<br \/>\n\u0413\u043e\u043d\u0442\u044b \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u044b \u0443\u043a\u043b\u0430\u0434\u044b\u0432\u0430\u044e\u0442\u0441\u044f \u0432\u043d\u0430\u0445\u043b\u0435\u0441\u0442 \u0438 \u043a\u0440\u0435\u043f\u044f\u0442\u0441\u044f \u0434\u0440\u0443\u0433 \u0441 \u0434\u0440\u0443\u0433\u043e\u043c \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0433\u0432\u043e\u0437\u0434\u044f\u043c\u0438, \u043d\u043e \u0438 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u043c \u043a\u043b\u0435\u0435\u0432\u044b\u043c \u0437\u0430\u043c\u043a\u043e\u043c \u043f\u043e\u0434 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435\u043c \u00ab\u0431\u0438\u0442\u0443\u043c\u043d\u0430\u044f \u0441\u0432\u0430\u0440\u043a\u0430 \u0433\u043e\u043d\u0442\u043e\u0432\u00bb. \u042d\u0442\u043e \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u0437\u0430\u043f\u0430\u0442\u0435\u043d\u0442\u043e\u0432\u0430\u043d\u043d\u0430\u044f \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430 Docke.<br \/>\n\u041d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435<br \/>\n\u0413\u0438\u0431\u043a\u0430\u044f \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u0430 \u0443\u0441\u0442\u0430\u043d\u0430\u0432\u043b\u0438\u0432\u0430\u0435\u0442\u0441\u044f \u043d\u0430 \u043a\u0440\u043e\u0432\u043b\u044e \u0441 \u0443\u043a\u043b\u043e\u043d\u043e\u043c \u043e\