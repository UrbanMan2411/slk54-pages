\u043f\u043e\u044f\u0432\u043b\u0435\u043d\u0438\u0435 \u0441\u044b\u0440\u043e\u0441\u0442\u0438, \u043f\u043b\u0435\u0441\u0435\u043d\u0438 \u0438 \u0433\u0440\u0438\u0431\u043a\u0430. \u041e\u0434\u043d\u043e \u0438\u0437 \u0433\u043b\u0430\u0432\u043d\u044b\u0445 \u043f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432 \u0430\u043a\u0440\u0438\u043b\u043e\u0432\u044b\u0445 \u0438 \u0432\u0438\u043d\u0438\u043b\u043e\u0432\u044b\u0445 \u0441\u043e\u0444\u0438\u0442\u043e\u0432 &#8211; \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u043c\u043e\u043d\u0442\u0430\u0436\u0430 \u043f\u0440\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u043a\u0440\u0443\u0433\u043b\u044b\u0439 \u0433\u043e\u0434, \u0434\u0430\u0436\u0435 \u043f\u0440\u0438 \u043c\u0438\u043d\u0443\u0441\u043e\u0432\u044b\u0445 \u0442\u0435\u043c\u043f\u0435\u0440\u0430\u0442\u0443\u0440\u0430\u0445. \u0421\u043e\u0444\u0438\u0442\u044b Grand Line \u0442\u0430\u043a\u0436\u0435 \u043e\u0442\u043b\u0438\u0447\u0430\u044e\u0442\u0441\u044f \u0434\u043e\u043b\u0433\u043e\u0432\u0435\u0447\u043d\u043e\u0441\u0442\u044c\u044e \u0438 \u043d\u0430\u0434\u0435\u0436\u043d\u043e\u0441\u0442\u044c\u044e, \u043d\u0435 \u0442\u0440\u0435\u0431\u0443\u044e\u0442 \u043e\u0441\u043e\u0431\u043e\u0433\u043e \u0443\u0445\u043e\u0434\u0430 \u0438 \u043e\u0447\u0435\u043d\u044c \u043f\u0440\u043e\u0441\u0442\u044b \u0432 \u043c\u043e\u043d\u0442\u0430\u0436\u0435. \u0423\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0430 \u0441\u043e\u0444\u0438\u0442\u043e\u0432 \u043d\u0430 \u043a\u0440\u044b\u0448\u0435 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u043c \u0448\u0430\u0433\u043e\u043c \u0434\u043b\u044f \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044f \u043d\u0430\u0434\u0435\u0436\u043d\u043e\u0439 \u0438 \u0434\u043e\u043b\u0433\u043e\u0432\u0435\u0447\u043d\u043e\u0439 \u044d\u043a\u0441\u043f\u043b\u0443\u0430\u0442\u0430\u0446\u0438\u0438 \u043a\u0440\u044b\u0448\u0438.<\/p>\n<p>\u0410\u043a\u0440\u0438\u043b\u043e\u0432\u044b\u0435 \u0438 \u0432\u0438\u043d\u0438\u043b\u043e\u0432\u044b\u0435 \u0441\u043e\u0444\u0438\u0442\u044b \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u044b \u0432 \u0442\u0440\u0435\u0445 \u0432\u0438\u0434\u0430\u0445:<\/p>\n<p>\u0431\u0435\u0437 \u043f\u0435\u0440\u0444\u043e\u0440\u0430\u0446\u0438\u0438 &#8211; \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u043c \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u0442\u044c \u0442\u043e\u043b\u044c\u043a\u043e \u0442\u0430\u043c, \u0433\u0434\u0435 \u043d\u0435 \u043d\u0443\u0436\u043d\u0430 \u0432\u0435\u043d\u0442\u0438\u043b\u044f\u0446\u0438\u044f (\u0431\u0435\u0441\u0435\u0434\u043a\u0438, \u043d\u0430\u0432\u0435\u0441\u044b, \u0444\u0440\u043e\u043d\u0442\u043e\u043d\u043d\u044b\u0435 \u0441\u0432\u0435\u0441\u044b);<br \/>\n\u0441 \u0446\u0435\u043d\u0442\u0440\u0430\u043b\u044c\u043d\u043e\u0439 \u043f\u0435\u0440\u0444\u043e\u0440\u0430\u0446\u0438\u0435\u0439 &#8211; \u043d\u0430\u0438\u0431\u043e\u043b\u0435\u0435 \u043f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u044b\u0439 \u0442\u0438\u043f \u0441\u043e\u0444\u0438\u0442\u043e\u0432, \u043f\u0440\u043e\u0441\u0435\u0447\u043a\u0438 \u043d\u0430\u043d\u043e\u0441\u044f\u0442\u0441\u044f \u043d\u0430 \u0441\u0440\u0435\u0434\u043d\u044e\u044e \u043b\u0430\u043c\u0435\u043b\u044c;<br \/>\n\u0441 \u043f\u043e\u043b\u043d\u043e\u0439 \u043f\u0435\u0440\u0444\u043e\u0440\u0430\u0446\u0438\u0435\u0439 &#8211; \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f, \u0435\u0441\u043b\u0438 \u0432\u0435\u043d\u0442\u0438\u043b\u044f\u0446\u0438\u044f \u043f\u043e\u0434\u043a\u0440\u043e\u0432\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0430 \u0438\u043b\u0438 \u0447\u0435\u0440\u0434\u0430\u043a\u0430 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u043e\u0432\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0447\u0435\u0440\u0435\u0437 \u043a\u0430\u0440\u043d\u0438\u0437\u043d\u044b\u0439 \u0441\u0432\u0435\u0441<br \/>\n\u041a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u044f \u0432\u0438\u043d\u0438\u043b\u043e\u0432\u044b\u0445 \u0441\u043e\u0444\u0438\u0442\u043e\u0432 Classic (\u041a\u043b\u0430\u0441\u0441\u0438\u043a\u0430) \u2013 \u0431\u0430\u043b\u0430\u043d\u0441 \u0432\u044b\u0441\u043e\u043a\u043e\u0433\u043e \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430 \u0438 \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e\u0439 \u0446\u0435\u043d\u044b.<br \/>\n\u041f\u0430\u043b\u0438\u0442\u0440\u0430 \u0432\u0438\u043d\u0438\u043b\u043e\u0432\u044b\u0445 \u0441\u043e\u0444\u0438\u0442\u043e\u0432 \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438 Classic &#8211; \u0441\u043e\u0441\u0442\u043e\u0438\u0442 \u0438\u0437 4 \u043e\u0442\u0442\u0435\u043d\u043a\u043e\u0432: \u0431\u0435\u043b\u044b\u0439, \u0441\u0435\u0440\u044b\u0439 \u0433\u0440\u0430\u0444\u0438\u0442, \u0448\u043e\u043a\u043e\u043b\u0430\u0434\u043d\u044b\u0439, \u043a\u043e\u0440\u0438\u0447\u043d\u0435\u0432\u044b\u0439.<br \/>\n\u0421\u043e\u0444\u0438\u0442\u044b Classic \u043e\u0431\u043b\u0430\u0434\u0430\u044e\u0442 \u0432\u0441\u0435\u043c\u0438 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u043c\u0438 \u0441\u0432\u043e\u0439\u0441\u0442\u0432\u0430\u043c\u0438 \u0434\u043b\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0434\u043e\u043b\u0433\u043e\u0432\u0435\u0447\u043d\u044b\u0445 \u0438 \u043d\u0430\u0434\u0435\u0436\u043d\u044b\u0445 \u043f\u0440\u043e\u0435\u043a\u0442\u043e\u0432: \u0441\u0442\u043e\u0439\u043a\u043e\u0441\u0442\u044c\u044e \u043a \u0432\u043e\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044e \u0432\u043d\u0435\u0448\u043d\u0438\u0445 \u0444\u0430\u043a\u0442\u043e\u0440\u043e\u0432, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0441\u04