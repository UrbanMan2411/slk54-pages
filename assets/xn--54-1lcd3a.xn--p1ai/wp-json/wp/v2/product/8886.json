c\u044b\u043c\u0438 \u0440\u0430\u0437\u043d\u044b\u043c\u0438 \u0446\u0432\u0435\u0442\u0430\u043c\u0438 \u0444\u0430\u0441\u0430\u0434\u0430. \u0413\u0438\u0431\u043a\u0443\u044e \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u0443 \u043c\u043e\u043d\u0442\u0438\u0440\u0443\u044e\u0442 \u043d\u0430 \u0441\u043f\u043b\u043e\u0448\u043d\u043e\u0435 \u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0438\u0435 \u043a\u0440\u043e\u0432\u043b\u0438, \u043a\u043e\u0442\u043e\u0440\u043e\u0435 \u0441\u043e\u043e\u0440\u0443\u0436\u0430\u044e\u0442, \u0432 \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u043c, \u0438\u0437 \u0432\u043b\u0430\u0433\u043e\u0441\u0442\u043e\u0439\u043a\u043e\u0439 \u0444\u0430\u043d\u0435\u0440\u044b.<br \/>\n\u041a\u0430\u0447\u0435\u0441\u0442\u0432\u043e Docke<br \/>\n\u041e\u0434\u043d\u043e \u0438\u0437 \u043a\u043b\u044e\u0447\u0435\u0432\u044b\u0445 \u043e\u0442\u043b\u0438\u0447\u0438\u0439, \u043a\u043e\u0442\u043e\u0440\u043e\u0435 \u0437\u0430\u043c\u0435\u0442\u043d\u043e \u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0432\u0430\u0435\u0442 \u0441\u0440\u043e\u043a \u0441\u043b\u0443\u0436\u0431\u044b \u043e\u0434\u043d\u043e\u0441\u043b\u043e\u0439\u043d\u043e\u0439 \u0433\u0438\u0431\u043a\u043e\u0439 \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u044b \u0441\u0435\u0440\u0438\u0438 \u00abPremium\u00bb, \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435 SBS-\u043c\u043e\u0434\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0433\u043e \u0431\u0438\u0442\u0443\u043c\u0430 \u0432\u043c\u0435\u0441\u0442\u043e \u043e\u043a\u0438\u0441\u043b\u0435\u043d\u043d\u043e\u0433\u043e. \u0422\u0430\u043a\u0430\u044f \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u0430 \u0431\u043e\u043b\u0435\u0435 \u0433\u0438\u0431\u043a\u0430\u044f \u0438 \u0443\u0441\u0442\u043e\u0439\u0447\u0438\u0432\u0430\u044f \u043a \u043c\u0435\u0445\u0430\u043d\u0438\u0447\u0435\u0441\u04