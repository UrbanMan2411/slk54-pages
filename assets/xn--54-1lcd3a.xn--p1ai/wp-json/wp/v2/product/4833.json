0431\u043e\u0436\u0436\u0451\u043d\u043d\u043e\u0439 \u0433\u043b\u0438\u043d\u044b, \u043a\u043e\u0442\u043e\u0440\u0443\u044e \u043b\u044e\u0434\u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043b\u0438 \u0434\u043b\u044f \u043f\u043e\u043a\u0440\u044b\u0442\u0438\u044f \u043a\u0440\u043e\u0432\u043b\u0438 \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u043c\u043d\u043e\u0433\u0438\u0445 \u0442\u044b\u0441\u044f\u0447 \u043b\u0435\u0442.<\/p>\n<p>\u041f\u0440\u0438 \u0442\u0430\u043a\u0438\u0445 \u043f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430\u0445, \u043a\u0430\u043a, \u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u043f\u0440\u043e\u0447\u043d\u043e\u0441\u0442\u044c, \u0434\u043e\u043b\u0433\u043e\u0432\u0435\u0447\u043d\u043e\u0441\u0442\u044c \u0438 \u043d\u0430\u0440\u044f\u0434\u043d\u044b\u0439 \u0432\u043d\u0435\u0448\u043d\u0438\u0439 \u0432\u0438\u0434, \u043a\u043b\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u0430 \u0438\u043c\u0435\u0435\u0442 \u0438 \u043d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043a\u0438: \u0431\u043e\u043b\u044c\u0448\u043e\u0439 \u0432\u0435\u0441, \u0442\u0440\u0435\u0431\u0443\u044e\u0449\u0438\u0439 \u0443\u0441\u0438\u043b\u0435\u043d\u043d\u043e\u0439 \u043e\u0431\u0440\u0435\u0448\u0451\u0442\u043a\u0438, \u0441\u043b\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u043c\u043e\u043d\u0442\u0430\u0436\u0430, \u043d\u0443 \u0438, \u0431\u0435\u0437\u0443\u0441\u043b\u043e\u0432\u043d\u043e, \u0432\u044b\u0441\u043e\u043a\u0430\u044f \u0446\u0435\u043d\u0430.<\/p>\n<p>\u041c\u0435\u0442\u0430\u043b\u043b\u043e\u0447\u0435\u0440\u0435\u043f\u0438\u0446\u0430 \u0421\u0443\u043f\u0435\u0440\u043c\u043e\u043d\u0442\u0435\u0440\u0440\u0435\u0439 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0431\u043e\u043b\u0435\u0435 \u044d\u043a\u043e\u043d\u043e\u043c\u0438\u0447\u043d\u044b\u043c \u0440\u0435\u0448\u0435\u043d\u0438\u0435\u043c, \u043e\u043d\u0430 \u043f\u0440\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u043d\u0435 \u0443\u0441\u0442\u0443\u043f\u0430\u0435\u0442 \u0432\u043e \u0432\u043d\u0435\u0448\u043d\u0435\u043c \u0432\u0438\u0434\u0435 \u0441\u0432\u043e\u0435\u0439 \u0441\u0442\u0430\u0440\u0438\u043d\u043d\u043e\u0439 \u043f\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u0446\u0435, \u0437\u0430\u043c\u0435\u0442\u043d\u043e \u043f\u0440\u0435\u0432\u043e\u0441\u0445\u043e\u0434\u044f \u0435\u0451 \u043f\u0440\u0438 \u044d\u0442\u043e\u043c \u0432 \u043f\u0440\u043e\u0441\u0442\u043e\u0442\u0435 \u0438 \u0443\u0434\u043e\u0431\u0441\u0442\u0432\u0435 \u043c\u043e\u043d\u0442\u0430\u0436\u0430.<\/p>\n<p>\u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u043d\u0435\u0431\u043e\u043b\u044c\u0448\u043e\u043c\u0443 \u0432\u0435\u0441\u0443 (\u043c\u0435\u043d\u0435\u0435 6 \u043a\u0433\/\u043c2, \u0447\u0442\u043e \u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e \u0432 \u0434\u0435\u0441\u044f\u0442\u044c \u0440\u0430\u0437 \u043b\u0435\u0433\u0447\u0435 \u043a\u043b\u0430\u0441\u0441\u0438\u043a\u0438) \u043d\u0430\u0433\u0440\u0443\u0437\u043a\u0430 \u043d\u0430 \u043e\u0431\u0440\u0435\u0448\u0451\u0442\u043a\u0443 \u0433\u043e\u0440\u0430\u0437\u0434\u043e \u043c\u0435\u043d\u044c\u0448\u0435, \u044d\u0442\u043e \u0437\u0430\u043c\u0435\u0442\u043d\u043e \u0441\u043d\u0438\u0436\u0430\u0435\u0442 \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u0438\u044f \u043a \u043f\u0440\u043e\u0447\u043d\u043e\u0441\u0442\u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u043c\u044b\u0445 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u0432.<\/p>\n<p>\u042d\u0442\u0430 \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u0430 \u043f\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0432 \u043b\u0438\u0441\u0442\u0430\u0445 \u0441 \u0440\u0430\u0431\u043e\u0447\u0435\u0439 \u0448\u0438\u0440\u0438\u043d\u043e\u0439 1100 \u043c\u043c \u0438 \u0434\u043b\u0438\u043d\u043e\u0439 \u0434\u043e 6 \u043c\u0435\u0442\u0440\u043e\u0432, \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0438\u0432\u0430\u044f \u0431\u044b\u0441\u0442\u0440\u044b\u0439 \u0438 \u043f\u0440\u043e\u0441\u0442\u043e\u0439 \u043c\u043e\u043d\u0442\u0430\u0436, \u0430 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0434\u043b\u0438\u043d\u0443 \u043e\u0442 0,85 \u043c\u0435\u0442\u0440\u0430 \u0441 \u0448\u0430\u0433\u043e\u043c 5 \u0441\u043c \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u043f\u0440\u0438\u043e\u0431\u0440\u0435\u0441\u0442\u0438 \u043b\u0438\u0441\u0442\u044b \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0439 \u0438\u043c\u0435\u043d\u043d\u043e \u0432\u0430\u043c \u0434\u043b\u0438\u043d\u044b, \u044d\u043a\u043e\u043d\u043e\u043c\u044f \u043d\u0430 \u043e\u0431\u0440\u0435\u0437\u043a\u0430\u0445.<\/p>\n<p>\u041c\u0435\u0442\u0430\u043b\u043b\u043e\u0447\u0435\u0440\u0435\u043f\u0438\u0446\u0430 \u0421\u0443\u043f\u0435\u0440\u043c\u043e\u043d\u0442\u0435\u0440\u0440\u0435\u0439 \u0438\u0437\u0433\u043e\u0442\u0430\u0432\u043b\u0438\u0432\u0430\u0435\u0442\u0441\u044f \u0438\u0437 \u0432\u044b\u0441\u043e\u043a\u043e\u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u0445\u043e\u043b\u043e\u0434\u043d\u043e\u043a\u0430\u0442\u0430\u043d\u043d\u043e\u0433\u043e \u043c\u0435\u0442\u0430\u043b\u043b\u0430 \u0442\u043e\u043b\u0449\u0438\u043d\u043e\u0439 0,4\u20130,5 \u043c\u043c, \u043e\u0446\u0438\u043d\u043a\u043e\u0432\u0430\u043d\u043d\u043e\u0433\u043e \u0433\u043e\u0440\u044f\u0447\u0438\u043c \u0441\u043f\u043e\u0441\u043e\u0431\u043e\u043c, \u0447\u0442\u043e, \u0432 \u0441\u043e\u0447\u0435\u0442\u0430\u043d\u0438\u0438 \u0441 \u043d\u0430\u043d\u0435\u0441\u0451\u043d\u043d\u044b\u043c \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u043c \u0434\u0435\u043a\u043e\u0440\u0430\u0442\u0438\u0432\u043d\u044b\u043c \u043f\u043e\u043a\u0440\u044b\u0442\u0438\u0435\u043c (\u041c\u0410\u0422\u0422, \u043f\u043e\u043b\u0438\u043c\u0435\u0440\u043d\u044b\u043c \u0438\u043b\u0438 \u0422\u0435\u0440\u0440\u0430\u043a\u043e\u0442) \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0440\u0443\u0435\u0442 \u0441\u0440\u043e\u043a \u0441\u043b\u0443\u0436\u0431\u044b \u0434\u043e 40 \u043b\u0435\u0442. \u0411\u043e\u043b\u0435\u0435 \u043f\u043e\u0434\u0440\u043e\u0431\u043d\u043e \u043e \u0432\u0438\u0434\u0430\u0445 \u043f\u043e\u043a\u0440\u044b\u0442\u0438\u0439.<\/p>\n<p>\u041f\u0440\u043e\u0444\u0438\u043b\u044c \u0421\u0443\u043f\u0435\u0440\u043c\u043e\u043d\u0442\u0435\u0440\u0440\u0435\u0439 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u043d\u043e\u0439 \u0432\u0435\u0440\u0441\u0438\u0435\u0439 \u0431\u0430\u0437\u043e\u0432\u043e\u0439 \u0441\u0435\u0440\u0438\u0438 \u041c\u043e\u043d\u0442\u0435\u0440\u0440\u0435\u0439, \u0432\u044b\u0433\u043e\u0434\u043d\u043e \u043e\u0442\u043b\u0438\u0447\u0430\u044f\u0441\u044c \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u043d\u043e\u0439 \u0438\u043c\u0438\u0442\u0430\u0446\u0438\u0435\u0439 \u0432\u0438\u0434\u0430 \u043a\u043b\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0447\u0435\u0440\u0435\u043f\u0438\u0446\u044b. \u042d\u0442\u043e \u0434\u043e\u0441\u0442\u0438\u0433\u0430\u0435\u0442\u0441\u044f \u0443\u0432\u0435\u043b\u0438\u0447\u0435\u043d\u0438\u0435\u043c \u0434\u043e 21 \u043c\u043c \u0432\u044b\u0441\u043e\u0442\u044b \u043f\u0440\u043e\u0444\u0438\u043b\u044f \u043b\u0438\u0441\u0442\u0430.<\/p>\n<p>\u042d\u0442\u0430 \u043c\u043e\u0434\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u044f \u0442\u0430\u043a\u0436\u0435 \u0437\u0430\u043c\u0435\u0442\u043d\u043e \u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0432\u0430\u0435\u0442 \u043f\u0440\u043e\u0447\u043d\u043e\u0441\u0442\u044c \u0438 \u0436\u0435\u0441\u0442\u043a\u043e\u0441\u0442\u044c \u043b\u0438\u0441\u0442\u0430.<\/p>\n<p>\u0428\u0430\u0433 \u0432\u043e\u043b\u043d\u044b \u2013 350 \u043c\u043c, \u0430 \u0435\u0451 \u0430\u0441\u0441\u0438\u043c\u0435\u0442\u0440\u0438\u0447\u043d\u044b\u0439 \u043f\u0440\u043e\u0444\u0438\u043b\u044c \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0438\u0432\u0430\u0435\u0442 \u043d\u0435\u043f\u043e\u0432\u0442\u043e\u0440\u0438\u043c\u0443\u044e \u0438\u0433\u0440\u0443 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u043e\u0433\u043e \u0441\u0432\u0435\u0442\u0430, \u043f\u0440\u0438\u0434\u0430\u0432\u0430\u044f \u043a\u0440\u043e\u0432\u043b\u0435 \u043e\u0441\u043e\u0431\u0443\u044e \u043f\u0440\u0438\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u0426\u0435\u043d\u0430 \u0443\u043a\u0430\u0437\u0430\u043d\u0430 \u0437\u0430 1 \u043c2<br \/>\n\u0422\u043e\u043b\u0449\u0438\u043d\u0430 0.45 \u043c\u043c<br \/>\n\u0414\u043b\u0438\u043d\u0430 \u043b\u0438\u0441\u0442\u0430 \u043e\u0442 0.85 \u0434\u043e 8 \u043c<br \/>\n\u0428\u0438\u0440\u0438\u043d\u0430 \u043b\u0438\u0441\u0442\u0430 \u043e\u0431\u0449\u0430\u044f1180 \u043c\u043c<br \/>\n\u0428\u0438\u0440\u0438\u043d\u0430 \u043b\u0438\u0441\u0442\u0430 \u0440\u0430\u0431\u043e\u0447\u0430\u044f1100 \u043c\u043c<br \/>\n\u0428\u0438\u0440\u0438\u043d\u0430 \u043b\u0438\u0441\u0442\u0430 1180<br \/>\n\u041f\u043e\u043a\u0440\u044b\u0442\u0438\u0435 \u041c\u0410\u0422\u0422<\/p>\n","protected":false},"featured_media":4838,"template":"","meta":[],"product_cat":[88],"product_tag":[],"class_list":["post-4833","product","type-product","status-publish","has-post-thumbnail","hentry","product_cat-metal-tile"],"_links":{"self":[{"href":"https:\/\/xn--54-1lcd3a.xn--p1ai\/wp-json\/wp\/v2\/product\/4833","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/xn--54-1lcd3a.xn--p1ai\/wp-json\/wp\/v2\/product"}],"about":