	<item>
		<title>Фидбросайдинг DECOVER</title>
		<link>https://xn--54-1lcd3a.xn--p1ai/product/%d1%84%d0%b8%d0%b4%d0%b1%d1%80%d0%be%d1%81%d0%b0%d0%b9%d0%b4%d0%b8%d0%bd%d0%b3-decover-15/</link>
		
		<dc:creator><![CDATA[slk54]]></dc:creator>
